ENABLE_NOTION=false

NVCF_API_KEY=your_nvidia_api_key_here
NVCF_FUNCTION_ID=your_nvidia_whisper_function_id_here
NVCF_FUNCTION_VERSION_ID=
NVCF_GRPC_SERVER=grpc.nvcf.nvidia.com:443
NVCF_USE_SSL=true
NVCF_SSL_CERT=

# Optional Notion publishing
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Whisper Large v3 usually works best with an accurate language code.
RIVA_LANGUAGE_CODE=en-US
RIVA_SAMPLE_RATE_HZ=16000
RIVA_MAX_ALTERNATIVES=1
RIVA_ENABLE_AUTOMATIC_PUNCTUATION=true
RIVA_VERBATIM_TRANSCRIPTS=false

# Pipeline tuning
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_SECONDS=5
RETRY_MAX_DELAY_SECONDS=120
FILE_SETTLE_SECONDS=10
SCAN_INTERVAL_SECONDS=5
LOG_LEVEL=INFO
